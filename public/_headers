# Cloudflare Pages response headers (copied into out/ via public/).
# Fingerprinted Next chunks — safe to cache forever.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# WenKai subsets — long-lived; filenames are not content-hashed, so no immutable.
/fonts/wenkai/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Poem HTML + RSC flight payloads — warm consecutive reads; refresh within an hour.
/p/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Client-loaded indexes
/poem-slugs.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/search-index.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
